# ─────────────────────────────────────────────────────────
# IntelliHire — Microsoft Azure Stack
# Copy to .env and fill in values from Azure Portal
# ─────────────────────────────────────────────────────────

APP_NAME=IntelliHire
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ── Azure Cosmos DB (MongoDB API) ────────────────────────
# From: Azure Portal → Cosmos DB → Connection strings
MONGODB_URL=mongodb://intellihire-cosmos:XXXXXXXXXX@intellihire-cosmos.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false
MONGODB_DB_NAME=intellihire

# ── Azure OpenAI ─────────────────────────────────────────
# From: Azure Portal → Azure OpenAI → Keys and Endpoint
LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Fallback: Standard OpenAI (while Azure OpenAI pending) ─
OPENAI_API_KEY=sk-...

# ── Azure Blob Storage ────────────────────────────────────
# From: Azure Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=intellihire-uploads
USE_AZURE_STORAGE=false

# ── CORS: Azure Static Web Apps + GitHub Pages ───────────
ALLOWED_ORIGINS=https://YOUR-APP.azurestaticapps.net,https://student-cybrarians.github.io
